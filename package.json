{
  "name": "supercompute",
  "version": "1.1.0",
  "description": "QUANTA - Sovereign Compute Platform on Base Chain",
  "type": "module",
  "scripts": {
    "dev": "tinacms dev -c \"wrangler dev\"",
    "tina:dev": "tinacms dev -c \"next dev\"",
    "tina:build": "tinacms build",
    "build": "npx esbuild src/worker.js --bundle --outfile=dist/worker.js --format=esm --platform=neutral --target=es2020 --minify --external:ws --external:events --external:stream --external:https --external:http --external:url --external:net --external:tls --external:zlib",
    "next:build": "npx next build",
    "full:build": "npx tinacms build && npx next build",
    "deploy": "npm run full:build && npx wrangler pages deploy out --project-name=supercompute --commit-dirty=true",
    "db:create": "wrangler d1 create supercompute",
    "db:push": "wrangler d1 execute supercompute --local --file=./schema.sql",
    "db:push:prod": "wrangler d1 execute supercompute --file=./schema.sql --env production",
    "preview": "wrangler pages project . --preview"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "@tanstack/react-query": "^5.100.11",
    "@tinacms/cli": "^2.3.1",
    "fs-extra": "^11.3.5",
    "neo4j-driver": "^6.0.1",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tinacms": "^3.8.1",
    "viem": "^2.48.11",
    "wagmi": "^3.6.15"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.0.0"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
